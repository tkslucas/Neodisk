	<!-- Background checks are on by default (Settings toggle opts out);
	     installing always needs a user click (SUAutomaticallyUpdate stays
	     unset/false). Shipping this key also suppresses Sparkle's own
	     second-launch permission prompt. -->
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- EdDSA public key for update signatures; the matching private key lives
	     only in the release keychain and must never be committed anywhere. -->
